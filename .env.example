# Plantilla de variables de entorno del backend (07 seccion 6.2).
# Copiar a .env y rellenar; .env esta en .gitignore (NO se commitea).

# Puerto de escucha (opcional, default 8080).
PORT=8080

# Cadena de conexion pgx (OBLIGATORIA).
DATABASE_URL=postgres://purpura:CAMBIA_ESTO@localhost:5432/purpura?sslmode=disable

# Firma del JWT propio. HS256 (default) usa JWT_SECRET; RS256 usa el par de PEM.
JWT_SIGNING_METHOD=HS256
JWT_SECRET=CAMBIA_ESTO_por_un_secreto_largo_y_aleatorio
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
JWT_ISSUER=purpura-backend
JWT_AUDIENCE=purpura-app
JWT_TTL_SECONDS=86400

# Audience esperada del idToken de Google Sign-In (OBLIGATORIA).
GOOGLE_CLIENT_ID=CAMBIA_ESTO.apps.googleusercontent.com

# Cost de bcrypt (opcional, default 12).
BCRYPT_COST=12

# Lista de origenes CORS separada por comas (opcional, default *).
CORS_ALLOWED_ORIGINS=*

# Nivel de log: debug | info | warn | error (opcional, default info).
LOG_LEVEL=info

# Limite de tamano del cuerpo en bytes (opcional, default 1048576 = 1 MiB).
MAX_BODY_BYTES=1048576
